# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a product + price at https://dashboard.stripe.com/products
# Set price to $3.00, one-time payment, copy the price ID here
STRIPE_PRICE_ID=price_...

# ── Security ─────────────────────────────────────────────────────────────────
# Random string used to sign unlock tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your-random-secret-here

# ── Public URL ───────────────────────────────────────────────────────────────
# Used to build Stripe success/cancel redirect URLs and to lock CORS in prod.
# On Railway: https://your-app.up.railway.app
# On Render:  https://your-app.onrender.com
PUBLIC_URL=https://your-app.up.railway.app

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Observability (optional) ─────────────────────────────────────────────────
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backups ──────────────────────────────────────────────────────────────────
# Number of historical SQLite backups to keep (used by `npm run backup`).
BACKUP_KEEP=14

