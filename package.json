{
  "name": "slither-io-clone",
  "version": "1.1.0",
  "description": "Multiplayer Slither.io clone",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "lint": "eslint --ext .js server.js server/ shared/ tests/",
    "format": "prettier --write \"**/*.{js,json,md,html,css}\"",
    "backup": "node scripts/backup-sqlite.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "stripe": "^14.0.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "@sentry/node": "^7.99.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  }
}
